APP_ENV=development
SEARCH_PROVIDER=tavily
SYNTHESIS_PROVIDER=gemini

# --- FREE: Google Gemini (recommended) ---
# Get a free key at https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=AIza...
SYNTHESIS_MODEL=gemini-2.0-flash-lite

# --- PAID: OpenAI (optional alternative) ---
# SYNTHESIS_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# SYNTHESIS_MODEL=gpt-4.1-mini

TAVILY_API_KEY=tvly-...
MAX_CONTEXT_TOKENS=10000
RESERVED_ANSWER_TOKENS=1600
MAX_SOURCES=6
MAX_SEARCH_QUERIES=4
MAX_RESULTS_PER_QUERY=5
REQUEST_TIMEOUT_SECONDS=25
