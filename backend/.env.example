APP_ENV=development
SEARCH_PROVIDER=tavily
SYNTHESIS_PROVIDER=groq

# --- FREE: Groq (recommended - get key at https://console.groq.com) ---
GROQ_API_KEY=gsk_...
SYNTHESIS_MODEL=llama-3.3-70b-versatile

# --- FREE alt: Google Gemini (https://ai.google.dev) ---
# SYNTHESIS_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# SYNTHESIS_MODEL=gemini-2.0-flash-lite

# --- FREE alt: Hugging Face (Email-only signup, no phone) ---
# SYNTHESIS_PROVIDER=hf
# HF_API_KEY=hf_...
# SYNTHESIS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# --- PAID: OpenAI ---
# SYNTHESIS_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# SYNTHESIS_MODEL=gpt-4.1-mini

TAVILY_API_KEY=tvly-...
MAX_CONTEXT_TOKENS=10000
RESERVED_ANSWER_TOKENS=1600
MAX_SOURCES=6
MAX_SEARCH_QUERIES=4
MAX_RESULTS_PER_QUERY=5
REQUEST_TIMEOUT_SECONDS=25
